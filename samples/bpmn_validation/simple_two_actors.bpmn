<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://nimbus-skeleton/bpmn" exporter="nimbus-skeleton" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Process Skeleton" processRef="Process_1"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_1" name="Process Skeleton" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_1_Operator" name="Operator">
        <bpmn:flowNodeRef>Task_REQ-e9fab190</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_REQ-ae91bf6c</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_2_Supervisor" name="Supervisor">
        <bpmn:flowNodeRef>Task_REQ-7b0e308a</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_REQ-8af3bc67</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="start">
      <bpmn:outgoing>SequenceFlow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_REQ-e9fab190" name="The Operator shall log in to the control console and confirm the previous…">
      <bpmn:incoming>SequenceFlow_1</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_2</bpmn:outgoing>
      <bpmn:outgoing>SequenceFlow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_REQ-7b0e308a" name="The Supervisor must review the overnight alarm log before releasing the…">
      <bpmn:incoming>SequenceFlow_2</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_REQ-ae91bf6c" name="The Operator shall verify that all subsystem status indicators read nominal">
      <bpmn:incoming>SequenceFlow_3</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_REQ-8af3bc67" name="The Supervisor must countersign the handover log once the checks are complete">
      <bpmn:incoming>SequenceFlow_4</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="end">
      <bpmn:incoming>SequenceFlow_5</bpmn:incoming>
      <bpmn:incoming>SequenceFlow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="Task_REQ-e9fab190"/>
    <bpmn:sequenceFlow id="SequenceFlow_2" sourceRef="Task_REQ-e9fab190" targetRef="Task_REQ-7b0e308a"/>
    <bpmn:sequenceFlow id="SequenceFlow_3" sourceRef="Task_REQ-e9fab190" targetRef="Task_REQ-ae91bf6c"/>
    <bpmn:sequenceFlow id="SequenceFlow_4" sourceRef="Task_REQ-7b0e308a" targetRef="Task_REQ-8af3bc67"/>
    <bpmn:sequenceFlow id="SequenceFlow_5" sourceRef="Task_REQ-ae91bf6c" targetRef="EndEvent_1"/>
    <bpmn:sequenceFlow id="SequenceFlow_6" sourceRef="Task_REQ-8af3bc67" targetRef="EndEvent_1"/>
  </bpmn:process>
